# Google Maps keys used by Android native config and Flutter Places search.
GOOGLE_MAPS_PLATFORM_API_KEY=replace-with-your-google-maps-platform-key
GOOGLE_MAPS_PLACES_API_KEY=replace-with-your-google-maps-places-key

# Didit KYC workflow ID. This is safe to ship in the app; do not put API keys here.
DIDIT_WORKFLOW_ID=replace-with-your-didit-workflow-id

# Firebase callable functions region.
FIREBASE_FUNCTIONS_REGION=asia-southeast1

# Algolia search. Use a restricted Search-only API key scoped to the assets index.
ALGOLIA_APPLICATION_ID=replace-with-your-algolia-application-id
ALGOLIA_SEARCH_API_KEY=replace-with-your-restricted-algolia-search-key
ALGOLIA_ASSETS_INDEX_NAME=assets_dev

# Public Lend web app base URL used for legal pages.
LEND_WEB_BASE_URL=https://getlend.dev
